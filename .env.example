# Sanity CMS Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit your actual .env file to git.

# Your Sanity Project ID — found at sanity.io/manage → your project
PUBLIC_SANITY_PROJECT_ID=your-project-id-here

# Your Sanity Dataset name (usually "production")
PUBLIC_SANITY_DATASET=production

# Sanity API version — use one of the two available versions:
# v2021-03-25 (stable, older) or v2025-02-19 (latest)
PUBLIC_SANITY_API_VERSION=2025-02-19

# (Optional) Sanity Read Token — required for accessing draft content
# Generate at sanity.io/manage → your project → API → Tokens
SANITY_API_TOKEN=your-read-token-here
