---
/**
 * MerchGrid.astro
 * 
 * Grid produk Merch dan Panel Slide-in untuk detail & order form.
 */
import { merchItems } from '../../../data/merch';
import MerchOrderForm from './MerchOrderForm.astro';
---

<section class="w-full max-w-7xl mx-auto px-6 md:px-12 pb-32 bg-yokai-dark-blue">
  
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
    {merchItems.map((item) => (
      <div 
        class={`merch-card group relative cursor-pointer flex flex-col gap-4 ${!item.available ? 'pointer-events-none' : ''}`}
        data-item={JSON.stringify(item)}
      >
        <div class="relative w-full aspect-[4/3] overflow-hidden bg-yokai-white/5">
          <img 
            src={item.images[0]} 
            alt={item.name} 
            class="merch-img w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          
          {!item.available && (
            <div class="absolute inset-0 bg-yokai-dark-blue/70 backdrop-blur-[2px] flex items-center justify-center z-10">
              <span class="font-jakarta font-black uppercase text-yokai-white tracking-widest text-xl">SOLD OUT</span>
            </div>
          )}
        </div>

        <div class="flex flex-col">
          <h3 class="merch-title font-jakarta font-bold uppercase text-lg text-yokai-white leading-tight transition-colors duration-300 group-hover:text-yokai-purple">
            {item.name}
          </h3>
          <p class="font-inter text-sm text-yokai-white/60 tracking-wider">
            {item.currency} {item.price.toLocaleString('id-ID')}
          </p>
        </div>
      </div>
    ))}
  </div>

  <div id="m-panel-wrapper" class="fixed inset-0 z-[100] pointer-events-none" style="visibility: hidden;">
    
    <div id="m-panel-backdrop" class="absolute inset-0 bg-yokai-white/10 backdrop-blur-sm opacity-0 pointer-events-auto cursor-zoom-out"></div>
    
    <div id="m-panel" class="absolute top-0 right-0 h-full w-full max-w-md bg-yokai-dark-blue shadow-2xl flex flex-col pointer-events-auto overflow-y-auto translate-x-full">
      
      <div class="sticky top-0 bg-yokai-dark-blue/95 backdrop-blur-md z-20 flex justify-end p-6 border-b border-yokai-white/10">
        <button id="m-panel-close" class="text-yokai-white hover:text-yokai-purple transition-colors">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="flex flex-col p-6 pt-0">
        <div id="m-panel-images" class="w-full flex gap-4 overflow-x-auto snap-x snap-mandatory hide-scrollbar mb-6 pb-2">
        </div>

        <h2 id="m-panel-title" class="font-jakarta font-black uppercase text-2xl text-yokai-white leading-tight mb-2">TITLE</h2>
        <p id="m-panel-price" class="font-inter text-sm font-bold text-yokai-purple tracking-wider mb-6">PRICE</p>
        
        <p id="m-panel-desc" class="font-inter text-sm text-yokai-white/70 leading-relaxed mb-8">DESC</p>
        
        <div class="w-full h-[1px] bg-yokai-white/10 mb-2"></div>
        
        <MerchOrderForm />
      </div>
    </div>
  </div>

</section>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  import anime from 'animejs/lib/anime.es.js';

  const cards = document.querySelectorAll('.merch-card');
  const panelWrapper = document.getElementById('m-panel-wrapper');
  const panelBackdrop = document.getElementById('m-panel-backdrop');
  const panel = document.getElementById('m-panel');
  const panelClose = document.getElementById('m-panel-close');
  
  const pImages = document.getElementById('m-panel-images');
  const pTitle = document.getElementById('m-panel-title');
  const pPrice = document.getElementById('m-panel-price');
  const pDesc = document.getElementById('m-panel-desc');
  
  const formProductInput = document.getElementById('m-product') as HTMLInputElement;
  const formVariantContainer = document.getElementById('m-variant-container');
  const formVariantSelect = document.getElementById('m-variant') as HTMLSelectElement;

  let isPanelOpen = false;

  const openPanel = (itemData: any) => {
    if (isPanelOpen) return;
    isPanelOpen = true;

    if (pTitle) pTitle.innerText = itemData.name;
    if (pPrice) pPrice.innerText = `${itemData.currency} ${itemData.price.toLocaleString('id-ID')}`;
    if (pDesc) pDesc.innerText = itemData.description;
    if (formProductInput) formProductInput.value = itemData.name;

    if (pImages) {
      pImages.innerHTML = '';
      itemData.images.forEach((imgSrc: string) => {
        const img = document.createElement('img');
        img.src = imgSrc;
        img.className = 'w-[85%] aspect-[4/3] object-cover flex-shrink-0 snap-center bg-yokai-white/5';
        pImages.appendChild(img);
      });
    }

    if (formVariantContainer && formVariantSelect) {
      if (itemData.variants && itemData.variants.length > 0) {
        formVariantContainer.classList.remove('hidden');
        formVariantSelect.required = true;
        formVariantSelect.innerHTML = itemData.variants.map((v: string) => `<option value="${v}">${v}</option>`).join('');
      } else {
        formVariantContainer.classList.add('hidden');
        formVariantSelect.required = false;
        formVariantSelect.innerHTML = '';
      }
    }

    panelWrapper!.style.visibility = 'visible';
    document.body.style.overflow = 'hidden';
    
    anime({ targets: panelBackdrop, opacity: [0, 1], duration: 300, easing: 'linear' });
    anime({
      targets: panel,
      translateX: ['100%', '0%'],
      duration: 600,
      easing: 'easeInOutExpo'
    });
  };

  const closePanel = () => {
    if (!isPanelOpen) return;

    anime({ targets: panelBackdrop, opacity: [1, 0], duration: 400, easing: 'easeInQuart' });
    anime({
      targets: panel,
      translateX: ['0%', '100%'],
      duration: 500,
      easing: 'easeInExpo',
      complete: () => {
        panelWrapper!.style.visibility = 'hidden';
        document.body.style.overflow = '';
        isPanelOpen = false;
      }
    });
  };

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const dataStr = card.getAttribute('data-item');
      if (dataStr) openPanel(JSON.parse(dataStr));
    });
  });

  panelClose?.addEventListener('click', closePanel);
  panelBackdrop?.addEventListener('click', closePanel);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePanel();
  });
</script>
