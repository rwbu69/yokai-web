---
/**
 * ChekiGrid.astro
 */
import { chekiItems } from '../../../data/cheki';
import ChekiOrderForm from './ChekiOrderForm.astro';
---

<section class="w-full max-w-7xl mx-auto px-6 md:px-12 pb-32 bg-yokai-dark-blue">
  
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
    {chekiItems.map((item) => (
      <div 
        class={`cheki-card group relative cursor-pointer flex flex-col gap-4 ${!item.available ? 'pointer-events-none' : ''}`}
        data-item={JSON.stringify(item)}
      >
        <div class="relative w-full aspect-[3/4] overflow-hidden bg-yokai-white/5">
          <img 
            src={item.image} 
            alt={item.name} 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
          />
          
          {item.available ? (
            <div class="absolute inset-0 bg-yokai-dark-blue/40 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10">
              <span class="font-jakarta font-black uppercase text-yokai-white tracking-widest text-lg border border-yokai-white px-6 py-2 hover:bg-yokai-white hover:text-yokai-dark-blue transition-colors">
                ORDER
              </span>
            </div>
          ) : (
            <div class="absolute inset-0 bg-yokai-dark-blue/70 backdrop-blur-[2px] flex items-center justify-center z-10">
              <span class="font-jakarta font-black uppercase text-yokai-white tracking-widest text-lg">SOLD OUT</span>
            </div>
          )}
        </div>

        <div class="flex flex-col text-center">
          <h3 class="font-jakarta font-bold uppercase text-md text-yokai-white leading-tight mb-1">
            {item.name}
          </h3>
          <p class="font-inter text-xs text-yokai-white/60 tracking-wider">
            {item.currency} {item.price.toLocaleString('id-ID')}
          </p>
        </div>
      </div>
    ))}
  </div>

  <div id="c-panel-wrapper" class="fixed inset-0 z-[100] pointer-events-none flex flex-col justify-end" style="visibility: hidden;">
    
    <div id="c-panel-backdrop" class="absolute inset-0 bg-yokai-white/10 backdrop-blur-sm opacity-0 pointer-events-auto cursor-zoom-out"></div>
    
    <div id="c-panel" class="relative w-full bg-yokai-dark-blue shadow-[0_-10px_40px_rgba(0,0,0,0.5)] flex flex-col pointer-events-auto rounded-t-2xl max-h-[85vh] translate-y-full">
      
      <div class="sticky top-0 bg-yokai-dark-blue/95 backdrop-blur-md z-20 flex justify-between items-center p-6 border-b border-yokai-white/10 rounded-t-2xl">
        <h2 class="font-jakarta font-black uppercase text-xl text-yokai-white tracking-wider">ORDER CHEKI</h2>
        <button id="c-panel-close" class="text-yokai-white hover:text-yokai-purple transition-colors">
          <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="flex flex-col md:flex-row p-6 gap-8 overflow-y-auto">
        <div class="w-full md:w-1/3 flex flex-col gap-4">
          <img id="c-panel-img" src="" alt="Cheki" class="w-full aspect-[3/4] object-cover shadow-lg" />
          <div>
            <h3 id="c-panel-title" class="font-jakarta font-black uppercase text-xl text-yokai-white leading-tight mb-1">TITLE</h3>
            <p id="c-panel-price" class="font-inter text-sm font-bold text-yokai-purple tracking-wider mb-2">PRICE</p>
            <p id="c-panel-desc" class="font-inter text-xs text-yokai-white/70 leading-relaxed">DESC</p>
          </div>
        </div>
        
        <div class="w-full md:w-2/3">
          <ChekiOrderForm />
        </div>
      </div>
    </div>
  </div>

</section>

<script>
  import anime from 'animejs/lib/anime.es.js';

  const cards = document.querySelectorAll('.cheki-card');
  const panelWrapper = document.getElementById('c-panel-wrapper');
  const panelBackdrop = document.getElementById('c-panel-backdrop');
  const panel = document.getElementById('c-panel');
  const panelClose = document.getElementById('c-panel-close');
  
  const pImg = document.getElementById('c-panel-img') as HTMLImageElement;
  const pTitle = document.getElementById('c-panel-title');
  const pPrice = document.getElementById('c-panel-price');
  const pDesc = document.getElementById('c-panel-desc');
  const formProductInput = document.getElementById('c-product') as HTMLInputElement;

  let isPanelOpen = false;

  const openPanel = (itemData: any) => {
    if (isPanelOpen) return;
    isPanelOpen = true;

    if (pTitle) pTitle.innerText = itemData.name;
    if (pPrice) pPrice.innerText = `${itemData.currency} ${itemData.price.toLocaleString('id-ID')}`;
    if (pDesc) pDesc.innerText = itemData.description;
    if (pImg) pImg.src = itemData.image;
    if (formProductInput) formProductInput.value = itemData.name;

    panelWrapper!.style.visibility = 'visible';
    document.body.style.overflow = 'hidden';
    
    anime({ targets: panelBackdrop, opacity: [0, 1], duration: 300, easing: 'linear' });
    anime({
      targets: panel,
      translateY: ['100%', '0%'],
      duration: 600,
      easing: 'easeOutExpo'
    });
  };

  const closePanel = () => {
    if (!isPanelOpen) return;

    anime({ targets: panelBackdrop, opacity: [1, 0], duration: 400, easing: 'easeInQuart' });
    anime({
      targets: panel,
      translateY: ['0%', '100%'],
      duration: 500,
      easing: 'easeInExpo',
      complete: () => {
        panelWrapper!.style.visibility = 'hidden';
        document.body.style.overflow = '';
        isPanelOpen = false;
      }
    });
  };

  cards.forEach(card => {
    card.addEventListener('click', () => {
      const dataStr = card.getAttribute('data-item');
      if (dataStr) openPanel(JSON.parse(dataStr));
    });
  });

  panelClose?.addEventListener('click', closePanel);
  panelBackdrop?.addEventListener('click', closePanel);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePanel();
  });
</script>
