---
/**
 * ChekiClosed.astro
 */
import { chekiConfig } from '../../../data/cheki';
---
<div class="w-full min-h-[60vh] flex flex-col items-center justify-center px-6 text-center">
  <h2 class="font-jakarta font-black uppercase text-yokai-white text-2xl md:text-4xl tracking-tighter mb-4">
    {chekiConfig.closedMessage}
  </h2>
  <p class="font-inter text-yokai-white/60 text-xs tracking-widest uppercase">
    Follow our social media for updates.
    <br/>
    <a href="#" class="text-yokai-purple hover:text-yokai-white transition-colors mt-2 inline-block">@yokai_wotagei</a>
  </p>
</div>
