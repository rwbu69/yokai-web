---
/**
 * ChekiOrderForm.astro (Elegant Redesign)
 */
import { chekiItems } from '../../../data/cheki';
---
<div class="w-full max-w-xl mx-auto bg-yokai-dark-blue/40 backdrop-blur-2xl border border-yokai-white/10 p-10 md:p-14 shadow-2xl relative overflow-hidden">
  
  <!-- Decorative corner accents -->
  <div class="absolute top-0 left-0 w-8 h-8 border-t border-l border-yokai-white/30"></div>
  <div class="absolute top-0 right-0 w-8 h-8 border-t border-r border-yokai-white/30"></div>
  <div class="absolute bottom-0 left-0 w-8 h-8 border-b border-l border-yokai-white/30"></div>
  <div class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-yokai-white/30"></div>

  <form id="cheki-form" class="flex flex-col gap-10 w-full relative z-10">
    
    <div class="group relative">
      <label for="c-name" class="block font-jakarta font-bold text-xs uppercase tracking-[0.3em] text-yokai-white/50 mb-3 transition-colors group-focus-within:text-yokai-purple">NAMA LENGKAP</label>
      <input type="text" id="c-name" name="entry.name" required class="w-full bg-transparent border-b border-yokai-white/20 pb-3 font-inter text-xl text-yokai-white focus:outline-none focus:border-yokai-purple transition-all duration-300 rounded-none placeholder-yokai-white/10" placeholder="Jane Doe" />
    </div>

    <div class="group relative">
      <label for="c-wa" class="block font-jakarta font-bold text-xs uppercase tracking-[0.3em] text-yokai-white/50 mb-3 transition-colors group-focus-within:text-yokai-purple">NOMOR WHATSAPP</label>
      <input type="tel" id="c-wa" name="entry.wa" required class="w-full bg-transparent border-b border-yokai-white/20 pb-3 font-inter text-xl text-yokai-white focus:outline-none focus:border-yokai-purple transition-all duration-300 rounded-none placeholder-yokai-white/10" placeholder="08123456789" />
    </div>

    <div class="group relative">
      <label for="c-product" class="block font-jakarta font-bold text-xs uppercase tracking-[0.3em] text-yokai-white/50 mb-3 transition-colors group-focus-within:text-yokai-purple">PILIH MEMBER</label>
      <select id="c-product" name="entry.product" required class="w-full bg-transparent border-b border-yokai-white/20 pb-3 font-inter text-xl text-yokai-white focus:outline-none focus:border-yokai-purple appearance-none rounded-none cursor-pointer transition-all duration-300">
        <option value="" disabled selected class="bg-yokai-dark-blue text-yokai-white/50">-- Pilih Member --</option>
        {chekiItems.map(item => (
          <option value={item.name} disabled={!item.available} class="bg-yokai-dark-blue text-yokai-white">
            {item.name} {item.available ? '' : '(SOLD OUT)'}
          </option>
        ))}
      </select>
      <!-- Custom select arrow -->
      <div class="absolute right-0 bottom-4 pointer-events-none text-yokai-white/30 group-focus-within:text-yokai-purple transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </div>
    </div>

    <div class="group relative">
      <label for="c-qty" class="block font-jakarta font-bold text-xs uppercase tracking-[0.3em] text-yokai-white/50 mb-3 transition-colors group-focus-within:text-yokai-purple">JUMLAH</label>
      <input type="number" id="c-qty" name="entry.qty" min="1" value="1" required class="w-full bg-transparent border-b border-yokai-white/20 pb-3 font-inter text-xl text-yokai-white focus:outline-none focus:border-yokai-purple transition-all duration-300 rounded-none" />
    </div>

    <p id="c-error" class="text-red-500 text-xs font-inter hidden"></p>

    <button type="submit" id="c-submit-btn" class="mt-8 w-full bg-yokai-white text-yokai-dark-blue font-jakarta font-black uppercase tracking-[0.2em] text-lg py-5 hover:bg-yokai-purple hover:text-yokai-white transition-all duration-500 flex items-center justify-center gap-3 cursor-pointer group">
      <span class="c-btn-text">SUBMIT ORDER</span>
      <span class="c-loading-dots flex gap-2 hidden">
        <span class="w-2 h-2 bg-current rounded-full"></span>
        <span class="w-2 h-2 bg-current rounded-full"></span>
        <span class="w-2 h-2 bg-current rounded-full"></span>
      </span>
      <svg class="w-6 h-6 c-btn-text transform group-hover:translate-x-2 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
    </button>
  </form>
</div>

<script>
  import anime from "animejs/lib/anime.es.js";

  const ENDPOINT_URL = "https://script.google.com/macros/s/AKfycbwnpOzGpvaOfWIqN-Acy-uVKXLe3VaCS2n6zCs9SsaCJRXbVfdrtpVAqYqzCiJXtSHk/exec";

  const form = document.getElementById("cheki-form") as HTMLFormElement;
  const submitBtn = document.getElementById("c-submit-btn") as HTMLButtonElement;
  const btnTexts = submitBtn?.querySelectorAll(".c-btn-text");
  const loadingDots = submitBtn?.querySelector(".c-loading-dots") as HTMLElement;
  const errorMsg = document.getElementById("c-error") as HTMLElement;

  let loadingAnim: any;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    errorMsg.classList.add("hidden");
    submitBtn.disabled = true;
    btnTexts?.forEach(el => el.classList.add("hidden"));
    loadingDots.classList.remove("hidden");

    const dots = loadingDots.querySelectorAll("span");
    loadingAnim = anime({
      targets: dots,
      translateY: [-4, 4],
      direction: "alternate",
      loop: true,
      easing: "easeInOutSine",
      duration: 400,
      delay: anime.stagger(150),
    });

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const res = await fetch(ENDPOINT_URL, {
        method: "POST",
        body: JSON.stringify(data),
        headers: { "Content-Type": "text/plain;charset=utf-8" },
      });

      if (!res.ok) throw new Error("Network error");
      window.location.href = "/shop/order-success?type=cheki";
    } catch (err) {
      loadingAnim.pause();
      submitBtn.disabled = false;
      btnTexts?.forEach(el => el.classList.remove("hidden"));
      loadingDots.classList.add("hidden");
      errorMsg.textContent = "Gagal mengirim pesanan. Silakan coba lagi.";
      errorMsg.classList.remove("hidden");
    }
  });
</script>
