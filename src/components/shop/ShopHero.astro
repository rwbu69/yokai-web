---
/**
 * ShopHero.astro
 */
interface Props {
  title: string;
  subtitle: string;
}
const { title, subtitle } = Astro.props;
---
<section class="w-full pt-40 pb-12 px-6 md:px-12 flex flex-col items-center text-center relative z-10">
  <h1 class="font-jakarta font-black uppercase text-yokai-white text-5xl md:text-7xl tracking-tighter leading-none mb-4 drop-shadow-2xl">
    {title}
  </h1>
  <p class="font-inter text-yokai-white/80 text-xs md:text-sm tracking-widest uppercase max-w-lg drop-shadow-md">
    {subtitle}
  </p>
</section>
