---
/**
 * HeroAbout.astro
 *
 * Props are passed from about.astro which fetches them from Sanity.
 */
import bgImageFallback from '../../assets/hero-images/3.webp';

interface Props {
  label: string;
  line1: string;
  line2: string;
  sub: string;
  footerText: string;
  bgImage?: string;
}
const { label, line1, line2, sub, footerText, bgImage } = Astro.props;
---

<section
  class="hero-about relative w-full overflow-hidden flex flex-col justify-between"
  style="min-height: 100svh; padding: 7rem 2rem 3rem; background-color: #080508;"
>
  <div class="absolute inset-0 z-0 pointer-events-none" aria-hidden="true">
    <img
      src={bgImage || bgImageFallback.src}
      alt=""
      class="w-full h-full object-cover object-center"
      style="opacity: 0.12; mix-blend-mode: luminosity;"
      loading="eager"
    />
  </div>

  <span
    aria-hidden="true"
    class="pointer-events-none select-none absolute bottom-[-0.05em] left-0 z-0 font-jakarta font-black uppercase leading-none text-white"
    style="font-size: 21vw; opacity: 0.028; letter-spacing: -0.04em;"
  >
    YOKAI
  </span>

  <div class="about-hero-label relative z-10 flex items-center gap-4" style="opacity: 0; transform: translateY(10px);">
    <div class="w-8 h-[1px] bg-yokai-purple"></div>
    <span class="font-inter text-[9px] tracking-[0.55em] uppercase text-yokai-purple">{label}</span>
  </div>

  <div class="relative z-10 mt-auto pt-12">
    <div class="overflow-hidden">
      <h1
        class="about-hero-line-1 font-jakarta font-black uppercase leading-none text-yokai-white"
        style="font-size: clamp(2.8rem, 9.5vw, 8.5rem); letter-spacing: -0.04em; transform: translateY(105%);"
      >
        {line1}
      </h1>
    </div>
    <div class="overflow-hidden">
      <h1
        class="about-hero-line-2 font-jakarta font-black uppercase leading-none"
        style="font-size: clamp(2.8rem, 9.5vw, 8.5rem); letter-spacing: -0.04em; color: var(--yokai-purple); transform: translateY(105%);"
      >
        {line2}
      </h1>
    </div>

    <div class="overflow-hidden mt-8 max-w-lg">
      <p
        class="about-hero-sub font-outfit text-yokai-light-white/50 font-light leading-relaxed"
        style="font-size: clamp(0.875rem, 1.2vw, 1.05rem); opacity: 0;"
      >
        {sub}
      </p>
    </div>
  </div>

  <div class="about-hero-footer relative z-10 flex items-center justify-between mt-12" style="opacity: 0;">
    <span class="font-inter text-[8px] tracking-[0.5em] uppercase text-white/25">
      {footerText}
    </span>
    <a
      href="#our-story"
      class="group flex items-center gap-3 font-inter text-[8px] tracking-[0.4em] uppercase text-white/30 hover:text-yokai-purple"
      style="transition: color 0.3s cubic-bezier(0.4,0,0.2,1);"
    >
      Scroll
      <span class="w-6 h-[1px] bg-current" style="transition: width 0.4s cubic-bezier(0.4,0,0.2,1);"></span>
    </a>
  </div>
</section>

<script>
  import anime from 'animejs/lib/anime.es.js';

  anime.timeline({ easing: 'easeOutQuart' })
    .add({
      targets: '.about-hero-label',
      opacity: [0, 1],
      translateY: [10, 0],
      duration: 600,
    })
    .add({
      targets: '.about-hero-line-1',
      translateY: ['105%', '0%'],
      duration: 750,
    }, '-=300')
    .add({
      targets: '.about-hero-line-2',
      translateY: ['105%', '0%'],
      duration: 750,
    }, '-=580')
    .add({
      targets: '.about-hero-sub',
      opacity: [0, 1],
      translateY: [10, 0],
      duration: 600,
    }, '-=400')
    .add({
      targets: '.about-hero-footer',
      opacity: [0, 1],
      duration: 500,
    }, '-=300');
</script>
