---
/**
 * TrackRecord.astro
 *
 * Daftar pencapaian tim, diurutkan dari terbaru ke terlama.
 * Klik item → modal Anime.js berisi image, deskripsi, tombol YouTube (opsional).
 * Di bawah container ada NODE TIMELINE horizontal sebagai navigasi scroll.
 *
 * ──────────────────────────────────────────────────────────
 * CARA MENGUBAH DATA
 * ──────────────────────────────────────────────────────────
 * Edit array di src/components/about/trackRecord.ts.
 * Data tidak boleh diedit di file ini.
 *
 * ──────────────────────────────────────────────────────────
 * CARA MENGUBAH / MENONAKTIFKAN ANIMASI
 * ──────────────────────────────────────────────────────────
 * - Animasi entrance  : hapus blok IntersectionObserver di <script>
 * - Animasi modal     : hapus fungsi openModal & closeModal di <script>
 * - Node timeline     : hapus seluruh kode di bawah komentar "── NODE TIMELINE"
 * - Menonaktifkan semua: hapus seluruh dua blok <script>
 *
 * ──────────────────────────────────────────────────────────
 * CARA KERJA NODE TIMELINE
 * ──────────────────────────────────────────────────────────
 * Scrollbar bawaan disembunyikan via CSS.
 * Gantinya, ada node-based timeline di bawah list:
 *
 *   Line  : garis horizontal tipis (1px), membentang penuh
 *   Nodes : titik kecil (6px) untuk setiap item, spasi merata (flex space-between)
 *           Node "aktif" (terdekat dengan scroll saat ini) berubah warna ke
 *           yokai-purple dan sedikit membesar (8px) — via CSS transition pada
 *           .tr-node-dot, bukan Anime.js, karena Anime.js tidak menarget dot
 *   Tooltip: muncul saat hover node — teks "Bulan Tahun" (contoh: "Dec 2024")
 *            Animasi tooltip menggunakan Anime.js (opacity + translateY)
 *            CSS transition TIDAK digunakan pada tooltip
 *   Klik node : smooth-scroll list ke item yang bersangkutan
 *   Drag line : mousedown/touchstart pada area timeline (bukan pada node)
 *               → geser horizontal untuk mengontrol scroll position
 *
 * Untuk mengatur ukuran node, edit variabel NODE_NORMAL dan NODE_ACTIVE
 * di dalam <script> di bawah.
 */

import { trackRecords } from './trackRecord';

const records = trackRecords;
const recordsJson = JSON.stringify(records);
---

<section
  class="tr-section w-full border-t border-white/[0.06] py-20 px-6 md:px-12 lg:px-16"
  style="background-color: #080508;"
>
  <div class="max-w-[1400px] mx-auto">

    <!-- Section marker -->
    <div class="tr-header flex items-end justify-between border-b border-white/[0.07] pb-8">
      <div class="flex items-center gap-5">
        <span class="font-inter text-[9px] tracking-[0.6em] uppercase" style="color: rgba(255,255,255,0.18);">02</span>
        <div class="w-10 h-[1px]" style="background: rgba(160,69,187,0.5);"></div>
        <span class="font-inter text-[9px] tracking-[0.5em] uppercase" style="color: rgba(160,69,187,0.8);">Track Record</span>
      </div>
      <span class="font-inter text-[8px] tracking-[0.4em] uppercase hidden sm:block" style="color: rgba(255,255,255,0.2);">
        {records.length} Performances
      </span>
    </div>

    <!-- ── Scrollable list ──────────────────────────────────────────── -->
    <div
      id="tr-list"
      style="max-height: 50vh; overflow-y: auto; scrollbar-width: none;"
      aria-label="Track record list"
    >
      {records.map((r) => (
        <button
          class="tr-row"
          data-record-id={String(r.id)}
          type="button"
          aria-label={`Lihat detail: ${r.event}`}
          style="width: 100%; display: flex; flex-direction: column; align-items: flex-start; padding: 1.25rem 0; border: none; border-bottom: 1px solid rgba(255,255,255,0.06); background: transparent; cursor: pointer; text-align: left;"
        >
          <div style="display: flex; align-items: baseline; gap: 2rem; width: 100%; justify-content: space-between; flex-wrap: wrap; row-gap: 0.25rem;">
            <div style="display: flex; align-items: baseline; gap: 1.5rem;">
              <span class="font-inter" style="font-size: 8px; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(255,255,255,0.22); flex-shrink: 0; min-width: 5rem;">
                {r.date}
              </span>
              <span class="font-jakarta" style="font-size: clamp(0.95rem, 1.6vw, 1.3rem); font-weight: 700; text-transform: uppercase; letter-spacing: -0.02em; color: #fdfffd; line-height: 1.2;">
                {r.event}
              </span>
            </div>
            <span class="font-inter" style="font-size: 8px; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(160,69,187,0.65); flex-shrink: 0;">
              {r.achievement}
            </span>
          </div>
        </button>
      ))}
    </div>

    <!-- ── Node timeline ─────────────────────────────────────────────── -->
    <!--
      Drag area covers the full container (cursor: ew-resize on line hover).
      Nodes are positioned via flex space-between — no absolute math needed.
      Tooltip appears above each node via Anime.js, not CSS transition.
    -->
    <div
      id="tr-timeline"
      style="position: relative; margin-top: 20px; padding: 10px 0; user-select: none; cursor: default;"
      aria-hidden="true"
    >
      <!-- Background line (always visible, 1px) -->
      <div
        id="tr-tl-line"
        style="position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: rgba(255,255,255,0.08); transform: translateY(-50%); pointer-events: none;"
      ></div>

      <!-- Nodes row — flex space-between so positions are proportional -->
      <div style="position: relative; display: flex; justify-content: space-between; align-items: center; z-index: 1;">
        {records.map((r, i) => (
          <button
            class="tr-node"
            data-node-index={String(i)}
            type="button"
            aria-label={`Go to: ${r.event}`}
            style="position: relative; width: 24px; height: 24px; border: none; background: transparent; cursor: pointer; padding: 0; flex-shrink: 0; display: flex; align-items: center; justify-content: center;"
          >
            <!-- Visible dot — CSS transition allowed (not targeted by anime.js) -->
            <span
              class="tr-node-dot"
              style="width: 6px; height: 6px; border-radius: 50%; background: rgba(255,255,255,0.20); display: block; pointer-events: none;"
            ></span>

            <!-- Tooltip — Anime.js only, no CSS transition -->
            <span
              class="tr-node-tooltip font-inter"
              style="position: absolute; bottom: calc(100% + 4px); left: 50%; transform: translateX(-50%); font-size: 7px; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(255,255,255,0.7); white-space: nowrap; pointer-events: none; opacity: 0;"
            >
              {r.date}
            </span>
          </button>
        ))}
      </div>
    </div>

  </div>
</section>

<!-- ── Modal overlay ─────────────────────────────────────────────────────── -->
<div
  id="tr-overlay"
  aria-modal="true"
  role="dialog"
  style="display: none; position: fixed; inset: 0; z-index: 50; align-items: center; justify-content: center; background: rgba(0,0,0,0.80);"
>
  <div
    id="tr-modal"
    style="position: relative; width: 100%; max-width: 600px; margin: 1rem; border: 1px solid rgba(255,255,255,0.08); background-color: #0e080f;"
  >
    <!-- Image -->
    <div style="width: 100%; overflow: hidden; aspect-ratio: 16/7;">
      <img
        id="tr-modal-img"
        src=""
        alt=""
        style="width: 100%; height: 100%; object-fit: cover; object-position: center; opacity: 0.85; display: block;"
      />
    </div>

    <!-- Content -->
    <div style="padding: 1.75rem;">
      <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem;">
        <p id="tr-modal-date" class="font-inter" style="font-size: 8px; letter-spacing: 0.5em; text-transform: uppercase; color: rgba(160,69,187,0.7);"></p>
        <div style="width: 1rem; height: 1px; background: rgba(160,69,187,0.3);"></div>
        <p id="tr-modal-achievement" class="font-inter" style="font-size: 8px; letter-spacing: 0.4em; text-transform: uppercase; color: rgba(255,255,255,0.35);"></p>
      </div>

      <h3
        id="tr-modal-event"
        class="font-jakarta"
        style="font-weight: 900; text-transform: uppercase; color: #fdfffd; margin-bottom: 1rem; font-size: clamp(1.1rem, 2.2vw, 1.5rem); letter-spacing: -0.03em; line-height: 1.15;"
      ></h3>

      <p
        id="tr-modal-desc"
        class="font-outfit"
        style="color: rgba(235,224,232,0.55); font-weight: 300; line-height: 1.65; font-size: 0.875rem; max-width: 52ch;"
      ></p>

      <!-- YouTube CTA -->
      <div id="tr-yt-wrap" style="display: none; margin-top: 1.5rem;">
        <a
          id="tr-yt-btn"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="font-inter"
          style="display: inline-flex; align-items: center; gap: 0.75rem; font-size: 8px; letter-spacing: 0.45em; text-transform: uppercase; color: #fdfffd; border: 1px solid rgba(255,255,255,0.2); padding: 0.75rem 1.25rem; text-decoration: none;"
        >
          Watch on YouTube
          <svg width="13" height="9" viewBox="0 0 13 9" fill="currentColor" aria-hidden="true" style="opacity: 0.6;">
            <path d="M12.74 1.4A1.63 1.63 0 0 0 11.6.25C10.58 0 6.5 0 6.5 0S2.42 0 1.4.25A1.63 1.63 0 0 0 .26 1.4 17.1 17.1 0 0 0 0 4.5a17.1 17.1 0 0 0 .26 3.1A1.63 1.63 0 0 0 1.4 8.75C2.42 9 6.5 9 6.5 9s4.08 0 5.1-.25a1.63 1.63 0 0 0 1.14-1.15A17.1 17.1 0 0 0 13 4.5a17.1 17.1 0 0 0-.26-3.1ZM5.2 6.43V2.57L8.58 4.5 5.2 6.43Z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Close -->
    <button
      id="tr-close"
      type="button"
      aria-label="Close"
      class="font-inter"
      style="position: absolute; top: 0.875rem; right: 0.875rem; background: transparent; border: none; cursor: pointer; color: rgba(255,255,255,0.3); font-size: 8px; letter-spacing: 0.4em; text-transform: uppercase; display: flex; align-items: center; gap: 0.4rem; padding: 0.25rem;"
    >
      Close
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true">
        <path d="M1 1l8 8M9 1L1 9"/>
      </svg>
    </button>
  </div>
</div>

<style>
  /* Hide native scrollbar — scroll still works */
  #tr-list::-webkit-scrollbar { display: none; }

  /*
   * Node dot size/color transitions via CSS — safe because Anime.js does NOT
   * target .tr-node-dot. Anime.js only targets .tr-node-tooltip (opacity/translateY).
   */
  .tr-node-dot {
    transition: width 0.2s cubic-bezier(0.4,0,0.2,1),
                height 0.2s cubic-bezier(0.4,0,0.2,1),
                background 0.2s cubic-bezier(0.4,0,0.2,1);
  }
</style>

<!--
  ── DATA BRIDGE ──────────────────────────────────────────────────────────
  PENTING: <script define:vars> menghasilkan inline script (bukan ES module).
  JANGAN gunakan `import` di sini — gunakan hanya untuk set window variable.
-->
<script define:vars={{ recordsJson }}>
  window.__YOKAI_TR = JSON.parse(recordsJson);
</script>

<!--
  ── MAIN LOGIC ───────────────────────────────────────────────────────────
  Script terpisah — ES module, import diperbolehkan.
  Membaca data dari window.__YOKAI_TR yang di-set oleh script di atas.
-->
<script>
  import anime from 'animejs/lib/anime.es.js';

  var records = (window as any).__YOKAI_TR as Array<{
    id: number; event: string; date: string; achievement: string;
    image: string; description: string; youtube?: string;
  }> || [];

  var list    = document.getElementById('tr-list')!;
  var overlay = document.getElementById('tr-overlay')!;
  var modal   = document.getElementById('tr-modal')!;
  var rows    = Array.from(document.querySelectorAll<HTMLElement>('.tr-row'));
  var nodes   = Array.from(document.querySelectorAll<HTMLButtonElement>('.tr-node'));
  var dots    = Array.from(document.querySelectorAll<HTMLElement>('.tr-node-dot'));

  // ── Initial state — set via JS so fallback renders visible ──────────
  document.querySelector<HTMLElement>('.tr-header')!.style.opacity = '0';
  rows.forEach(function(r) { r.style.opacity = '0'; });

  // ── Entrance animation via IntersectionObserver ──────────────────────
  var entranceObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (!entry.isIntersecting) return;

      anime({
        targets: '.tr-header',
        opacity: [0, 1],
        translateY: [8, 0],
        duration: 500,
        easing: 'easeOutQuart',
      });

      anime({
        targets: '.tr-row',
        opacity: [0, 1],
        translateX: [-14, 0],
        duration: 450,
        easing: 'easeOutQuart',
        delay: anime.stagger(50, { start: 180 }),
      });

      entranceObserver.disconnect();
    });
  }, { threshold: 0.05 });

  var section = document.querySelector('.tr-section');
  if (section) entranceObserver.observe(section);

  // ══════════════════════════════════════════════════════════════════════
  //  NODE TIMELINE
  // ══════════════════════════════════════════════════════════════════════

  /**
   * Ukuran node — edit di sini untuk menyesuaikan.
   * NODE_NORMAL : ukuran dot dalam kondisi idle (px)
   * NODE_ACTIVE : ukuran dot yang aktif (paling dekat scroll position)
   *
   * CSS transition pada .tr-node-dot menganimasikan perubahan ukuran/warna ini.
   * Anime.js TIDAK menarget dot — tidak ada konflik.
   */
  var NODE_NORMAL = '6px';
  var NODE_ACTIVE = '8px';

  /** Rasio scroll saat ini (0–1) */
  function getScrollRatio(): number {
    var max = list.scrollHeight - list.offsetHeight;
    return max <= 0 ? 0 : list.scrollTop / max;
  }

  /** Update node aktif berdasarkan posisi scroll */
  function updateActiveNode() {
    var ratio = getScrollRatio();
    var n = nodes.length;
    if (n === 0) return;
    var activeIdx = Math.round(ratio * (n - 1));

    dots.forEach(function(dot, i) {
      if (i === activeIdx) {
        dot.style.width    = NODE_ACTIVE;
        dot.style.height   = NODE_ACTIVE;
        dot.style.background = 'var(--yokai-purple)';
      } else {
        dot.style.width    = NODE_NORMAL;
        dot.style.height   = NODE_NORMAL;
        dot.style.background = 'rgba(255,255,255,0.20)';
      }
    });
  }

  // Sync saat list di-scroll
  list.addEventListener('scroll', updateActiveNode);

  // Init saat load
  window.addEventListener('load', updateActiveNode);

  // ── Node hover: tooltip via Anime.js ──────────────────────────────────
  nodes.forEach(function(node, i) {
    var tooltip = node.querySelector<HTMLElement>('.tr-node-tooltip');

    // Hover: show tooltip
    node.addEventListener('mouseenter', function() {
      if (!tooltip) return;
      anime.remove(tooltip);
      anime({
        targets: tooltip,
        opacity: [0, 1],
        translateY: [5, 0],
        duration: 180,
        easing: 'easeOutQuart',
      });
    });

    // Hover: hide tooltip
    node.addEventListener('mouseleave', function() {
      if (!tooltip) return;
      anime.remove(tooltip);
      anime({
        targets: tooltip,
        opacity: 0,
        translateY: 5,
        duration: 120,
        easing: 'easeInQuart',
      });
    });

    // Click: smooth-scroll list ke item yang bersangkutan
    node.addEventListener('click', function() {
      var n = nodes.length;
      var ratio = n > 1 ? i / (n - 1) : 0;
      var maxScroll = list.scrollHeight - list.offsetHeight;
      list.scrollTo({ top: ratio * maxScroll, behavior: 'smooth' });
    });
  });

  // ── Drag on timeline line (click/drag anywhere except nodes) ─────────
  var timeline      = document.getElementById('tr-timeline');
  var isTlDragging  = false;

  function setScrollFromTimelineX(clientX: number) {
    if (!timeline) return;
    var rect  = timeline.getBoundingClientRect();
    var relX  = clientX - rect.left;
    var ratio = Math.min(Math.max(0, relX / rect.width), 1);
    var maxScroll = list.scrollHeight - list.offsetHeight;
    list.scrollTop = ratio * maxScroll;
    updateActiveNode();
  }

  if (timeline) {
    // Mouse drag
    timeline.addEventListener('mousedown', function(e: MouseEvent) {
      if ((e.target as HTMLElement).closest('.tr-node')) return; // ignore node clicks
      isTlDragging = true;
      setScrollFromTimelineX(e.clientX);
      e.preventDefault();
    });

    // Touch drag
    timeline.addEventListener('touchstart', function(e: TouchEvent) {
      if ((e.target as HTMLElement).closest('.tr-node')) return;
      isTlDragging = true;
      setScrollFromTimelineX(e.touches[0].clientX);
      e.preventDefault();
    }, { passive: false });
  }

  document.addEventListener('mousemove', function(e: MouseEvent) {
    if (!isTlDragging) return;
    setScrollFromTimelineX(e.clientX);
  });

  document.addEventListener('touchmove', function(e: TouchEvent) {
    if (!isTlDragging) return;
    setScrollFromTimelineX(e.touches[0].clientX);
  }, { passive: false });

  document.addEventListener('mouseup', function() { isTlDragging = false; });
  document.addEventListener('touchend', function() { isTlDragging = false; });

  // ══════════════════════════════════════════════════════════════════════
  //  MODAL
  // ══════════════════════════════════════════════════════════════════════

  function openModal(record: typeof records[0]) {
    var img    = document.getElementById('tr-modal-img') as HTMLImageElement;
    var evEl   = document.getElementById('tr-modal-event')!;
    var dateEl = document.getElementById('tr-modal-date')!;
    var achEl  = document.getElementById('tr-modal-achievement')!;
    var descEl = document.getElementById('tr-modal-desc')!;
    var ytWrap = document.getElementById('tr-yt-wrap')!;
    var ytBtn  = document.getElementById('tr-yt-btn') as HTMLAnchorElement;

    img.src              = record.image;
    img.alt              = record.event;
    evEl.textContent     = record.event;
    dateEl.textContent   = record.date;
    achEl.textContent    = record.achievement;
    descEl.textContent   = record.description;

    if (record.youtube) {
      ytWrap.style.display = '';
      ytBtn.href = record.youtube;
    } else {
      ytWrap.style.display = 'none';
    }

    anime.set(overlay, { opacity: 0 });
    anime.set(modal,   { translateY: 20, opacity: 0 });
    overlay.style.display = 'flex';
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(function() {
      anime({ targets: overlay, opacity: [0, 1], duration: 220, easing: 'easeOutQuart' });
      anime({ targets: modal,   translateY: [20, 0], opacity: [0, 1], duration: 380, easing: 'easeOutQuart' });
    });
  }

  function closeModal() {
    anime({
      targets: [overlay, modal],
      opacity: 0,
      duration: 200,
      easing: 'easeInQuart',
      complete: function() {
        overlay.style.display = 'none';
        document.body.style.overflow = '';
      },
    });
  }

  // ── Event bindings ────────────────────────────────────────────────────
  rows.forEach(function(row) {
    row.addEventListener('click', function() {
      var id  = Number(row.dataset.recordId);
      var rec = records.find(function(r) { return r.id === id; });
      if (rec) openModal(rec);
    });

    row.addEventListener('mouseenter', function() {
      var nameEl = row.querySelector<HTMLElement>('.font-jakarta');
      var achEl  = row.querySelector<HTMLElement>('.font-inter:last-of-type');
      if (nameEl) nameEl.style.color = 'var(--yokai-purple)';
      if (achEl)  achEl.style.color  = 'var(--yokai-purple)';
    });
    row.addEventListener('mouseleave', function() {
      var nameEl = row.querySelector<HTMLElement>('.font-jakarta');
      var achEl  = row.querySelector<HTMLElement>('.font-inter:last-of-type');
      if (nameEl) nameEl.style.color = '#fdfffd';
      if (achEl)  achEl.style.color  = 'rgba(160,69,187,0.65)';
    });
  });

  document.getElementById('tr-close')!.addEventListener('click', closeModal);

  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeModal();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.style.display !== 'none') closeModal();
  });
</script>
