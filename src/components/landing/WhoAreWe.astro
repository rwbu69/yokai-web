---
/**
 * WhoAreWe.astro
 */
import { urlFor } from '@lib/sanity';

import local1  from '../../assets/who-are-we/1.webp';
import local2  from '../../assets/who-are-we/2.webp';
import local3  from '../../assets/who-are-we/3.webp';
import local4  from '../../assets/who-are-we/4.webp';
import local5  from '../../assets/who-are-we/5.webp';
import local6  from '../../assets/who-are-we/6.webp';
import local7  from '../../assets/who-are-we/7.webp';
import local8  from '../../assets/who-are-we/8.webp';

interface Props {
  title: string;
  highlight: string;
  body: string;
  buttonText: string;
  images: any[];
}

const { title, highlight, body, buttonText, images = [] } = Astro.props;

let imagesA: string[] = [];
let imagesB: string[] = [];
let imagesC: string[] = [];

if (images && images.length === 12) {
  const w = 400; // Width for marquee
  const h = 300; // Height for consistent 4:3 aspect ratio
  const formattedImages = images.map((img: any) => urlFor(img).width(w).height(h).format('webp').url());
  imagesA = formattedImages.slice(0, 4);
  imagesB = formattedImages.slice(4, 8);
  imagesC = formattedImages.slice(8, 12);
} else {
  imagesA = [local1.src,  local2.src,  local3.src,  local4.src];
  imagesB = [local5.src,  local6.src,  local7.src,  local8.src];
  imagesC = [local1.src,  local2.src,  local3.src,  local4.src];
}
---

<section
  class="waw-section w-full bg-yokai-dark-blue py-32 relative overflow-hidden flex flex-col items-center justify-center min-h-screen"
>
  <div class="absolute inset-0 z-0 pointer-events-none opacity-35 flex flex-col gap-1 justify-center">
    <div class="overflow-hidden flex-shrink-0">
      <div class="flex w-max animate-slide-left gap-1">
        {[...imagesA, ...imagesA, ...imagesA, ...imagesA, ...imagesA, ...imagesA].map((src) => (
          <img src={src} alt="" class="h-[200px] md:h-[260px] lg:h-[320px] w-auto aspect-[4/3] flex-shrink-0 object-cover grayscale" />
        ))}
      </div>
    </div>
    <div class="overflow-hidden flex-shrink-0">
      <div class="flex w-max animate-slide-right gap-1">
        {[...imagesB, ...imagesB, ...imagesB, ...imagesB, ...imagesB, ...imagesB].map((src) => (
          <img src={src} alt="" class="h-[200px] md:h-[260px] lg:h-[320px] w-auto aspect-[4/3] flex-shrink-0 object-cover grayscale" />
        ))}
      </div>
    </div>
    <div class="overflow-hidden flex-shrink-0">
      <div class="flex w-max animate-slide-left-fast gap-1">
        {[...imagesC, ...imagesC, ...imagesC, ...imagesC, ...imagesC, ...imagesC].map((src) => (
          <img src={src} alt="" class="h-[200px] md:h-[260px] lg:h-[320px] w-auto aspect-[4/3] flex-shrink-0 object-cover grayscale" />
        ))}
      </div>
    </div>
  </div>

  <div
    class="absolute inset-0 z-0 pointer-events-none"
    style="background: linear-gradient(to top, var(--yokai-dark-blue) 0%, rgba(42,30,82,0.6) 50%, transparent 100%);"
  ></div>

  <div
    class="waw-content relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-end mt-auto mb-auto py-20"
  >
    <div class="lg:col-span-7 flex flex-col justify-end items-start text-left">
      <div class="waw-label flex items-center gap-4 mb-8" style="opacity: 0;">
        <div class="w-12 h-[2px] bg-yokai-purple"></div>
        <span class="font-inter text-xs font-bold tracking-[0.5em] uppercase text-yokai-purple">{title}</span>
      </div>

      <div class="waw-headline" style="opacity: 0; pointer-events: none;">
        <span class="font-jakarta text-3xl md:text-4xl lg:text-5xl font-black uppercase tracking-tighter text-white leading-tight mb-6 block break-words max-w-full"
              set:html={highlight.replace(',', ',<br/>')}
        >
        </span>
      </div>
    </div>

    <div
      class="waw-right lg:col-span-5 flex flex-col justify-end items-start text-left lg:border-l border-yokai-white/20 lg:pl-16 pt-10 lg:pt-0"
      style="opacity: 0;"
    >
      <p class="font-outfit text-lg md:text-xl lg:text-2xl text-yokai-light-white/80 leading-relaxed font-light tracking-wide mb-12">
        {body}
      </p>
      <div class="w-full flex justify-start lg:justify-end">
        <a
          href="/about"
          class="waw-cta group relative inline-flex items-center gap-4 text-xs font-inter font-bold tracking-[0.3em] uppercase text-yokai-white"
          style="transition: color 0.3s cubic-bezier(0.4,0,0.2,1);"
          onmouseover="this.style.color='var(--yokai-purple)'"
          onmouseout="this.style.color='#fdfffd'"
        >
          {buttonText}
          <span
            class="w-8 h-[1px] bg-current"
            style="transition: width 0.3s cubic-bezier(0.4,0,0.2,1);"
          ></span>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import anime from 'animejs/lib/anime.es.js';

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (!entry.isIntersecting) return;

      anime.timeline({ easing: 'easeOutQuart' })
        .add({
          targets:    '.waw-label',
          opacity:    [0, 1],
          translateY: [12, 0],
          duration:   500,
        })
        .add({
          targets:    '.waw-headline',
          opacity:    [0, 1],
          translateY: [28, 0],
          duration:   700,
        }, '-=200')
        .add({
          targets:    '.waw-right',
          opacity:    [0, 1],
          translateX: [30, 0],
          duration:   650,
        }, '-=500');

      observer.disconnect();
    });
  }, { threshold: 0.15 });

  var section = document.querySelector('.waw-section');
  if (section) observer.observe(section);
</script>
