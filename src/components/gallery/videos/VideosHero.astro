---
/**
 * VideosHero.astro
 * 
 * Hero section untuk halaman Videos.
 * Konsisten dengan PhotosHero namun dengan copy yang berbeda.
 * Warna dasar: yokai-light-white.
 */
---

<section class="w-full bg-yokai-light-white text-yokai-dark-blue pt-52 pb-20 px-6 lg:px-12 overflow-hidden relative">
  <div class="max-w-[90vw] mx-auto flex flex-col items-start relative z-10">
    
    <!-- Badge -->
    <div class="vh-hero-badge flex items-center gap-4 mb-6 opacity-0">
      <div class="w-8 h-[2px] bg-yokai-purple"></div>
      <span class="font-inter text-[10px] font-bold tracking-[0.4em] uppercase text-yokai-purple">
        Gallery Collection
      </span>
    </div>

    <!-- Title -->
    <h1 class="vh-hero-title font-jakarta font-black uppercase text-yokai-dark-blue leading-[0.9] tracking-tighter mb-8 max-w-5xl opacity-0" style="font-size: clamp(3rem, 8vw, 7rem);">
      Motion &<br/>Waza.
    </h1>

    <!-- Description -->
    <p class="vh-hero-desc font-outfit text-lg md:text-xl text-yokai-dark-blue/70 max-w-2xl leading-relaxed tracking-wide opacity-0 border-l-2 border-yokai-purple/30 pl-6">
      The precision of our routines, captured in motion. From underground practice sessions to full-scale stage performances.
    </p>

  </div>
</section>

<script>
  import anime from 'animejs/lib/anime.es.js';

  // Set initial state
  anime.set(['.vh-hero-badge', '.vh-hero-title', '.vh-hero-desc'], { opacity: 0, translateY: 30 });

  // Play animation on load
  anime.timeline({
    easing: 'easeOutExpo',
    duration: 1000
  })
  .add({
    targets: '.vh-hero-badge',
    opacity: [0, 1],
    translateY: [20, 0],
    delay: 200
  })
  .add({
    targets: '.vh-hero-title',
    opacity: [0, 1],
    translateY: [30, 0],
  }, '-=700')
  .add({
    targets: '.vh-hero-desc',
    opacity: [0, 1],
    translateY: [20, 0],
  }, '-=800');
</script>
