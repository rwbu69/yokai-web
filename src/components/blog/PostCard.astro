---
/**
 * PostCard.astro
 * 
 * Card komponen tunggal untuk merender post di halaman listing.
 * 
 * Props:
 * - title: string
 * - titleJp?: string
 * - description: string
 * - coverImage: string
 * - date: string
 * - slug: string
 * - collection: string
 */
interface Props {
  title: string;
  titleJp?: string;
  description: string;
  coverImage: string;
  date: string;
  slug: string;
  collection: string;
}

const { title, titleJp, description, coverImage, date, slug, collection } = Astro.props;
const postUrl = collection === 'updates' ? `/updates/${slug}` : `/library/${collection}/${slug}`;
---

<a href={postUrl} class="post-card group block w-full relative opacity-0 translate-y-4">
  <article class="flex flex-col gap-4">
    <!-- Image Box -->
    <div class="relative w-full h-[200px] overflow-hidden bg-white rounded-lg shadow-[0_4px_20px_rgba(42,30,82,0.05)] border border-[#2A1E52]/10">
      <img 
        src={coverImage} 
        alt={title} 
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      />
      <!-- Hover Overlay -->
      <div class="absolute inset-0 bg-[#A045BB]/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    </div>

    <!-- Content Box -->
    <div class="flex flex-col px-2 py-1">
      <time datetime={date} class="font-inter text-[10px] tracking-[0.2em] uppercase text-[#2A1E52]/50 mb-2 font-bold">
        {new Date(date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      
      {titleJp && (
        <h2 class="font-jakarta font-black text-2xl !text-[#2A1E52] leading-tight mb-1 transition-colors duration-300 group-hover:!text-[#A045BB]">
          {titleJp}
        </h2>
      )}
      
      <h3 class={`font-jakarta font-bold uppercase ${titleJp ? 'text-sm !text-[#2A1E52]/70' : 'text-lg !text-[#2A1E52]'} leading-tight mb-2 transition-colors duration-300 ${!titleJp && 'group-hover:!text-[#A045BB]'}`}>
        {title}
      </h3>
      
      <p class="font-inter text-sm !text-[#2A1E52]/80 line-clamp-2 mt-1">
        {description}
      </p>
    </div>
  </article>
</a>
