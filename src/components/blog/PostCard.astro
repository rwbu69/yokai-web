---
/**
 * PostCard.astro
 * 
 * Card komponen tunggal untuk merender post di halaman listing.
 * 
 * Props:
 * - title: string
 * - description: string
 * - coverImage: string
 * - date: string
 * - slug: string
 * - collection: string
 */
interface Props {
  title: string;
  description: string;
  coverImage: string;
  date: string;
  slug: string;
  collection: string;
}

const { title, description, coverImage, date, slug, collection } = Astro.props;
const postUrl = collection === 'updates' ? `/updates/${slug}` : `/library/${collection}/${slug}`;
---

<a href={postUrl} class="post-card group block w-full relative opacity-0 translate-y-4">
  <article class="flex flex-col gap-4">
    <!-- Image Box -->
    <div class="relative w-full h-[200px] overflow-hidden bg-yokai-white/5">
      <img 
        src={coverImage} 
        alt={title} 
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      />
      <!-- Hover Overlay -->
      <div class="absolute inset-0 bg-yokai-dark-blue/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
    </div>

    <!-- Content Box -->
    <div class="flex flex-col">
      <time datetime={date} class="font-inter text-[9px] tracking-[0.2em] uppercase text-yokai-white/40 mb-2">
        {new Date(date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h3 class="font-jakarta font-bold uppercase text-lg text-yokai-white leading-tight mb-2 transition-colors duration-300 group-hover:text-yokai-purple">
        {title}
      </h3>
      <p class="font-inter text-xs text-yokai-white/70 line-clamp-2">
        {description}
      </p>
    </div>
  </article>
</a>
