---
/**
 * PostHero.astro
 * 
 * Hero section untuk halaman listing collection.
 * 
 * Props:
 * - title: string
 * - description: string
 */
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---
<section class="w-full pt-40 pb-16 px-6 md:px-12 flex flex-col items-center text-center">
  <h1 class="font-jakarta font-black uppercase text-yokai-white text-4xl md:text-6xl tracking-tighter leading-none mb-4">
    {title}
  </h1>
  <p class="font-inter text-yokai-white/70 text-xs md:text-sm tracking-widest uppercase max-w-xl">
    {description}
  </p>
</section>
