---
/**
 * PostHeader.astro
 * 
 * Header di dalam halaman detail post ([slug].astro).
 * 
 * Props:
 * - title: string
 * - coverImage: string
 * - date: string
 * - tags?: string[]
 */
interface Props {
  title: string;
  coverImage: string;
  date: string;
  tags?: string[];
}

const { title, coverImage, date, tags } = Astro.props;
---
<header class="w-full h-[50vh] min-h-[400px] relative flex flex-col items-center justify-center pt-20 px-6 text-center">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0 overflow-hidden bg-yokai-white/5">
    <img src={coverImage} alt={title} class="w-full h-full object-cover opacity-60" />
    <div class="absolute inset-0 bg-gradient-to-t from-yokai-dark-blue via-yokai-dark-blue/80 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center max-w-4xl mx-auto">
    <h1 class="font-jakarta font-black uppercase text-yokai-white text-3xl md:text-5xl lg:text-6xl tracking-tighter leading-none mb-6 drop-shadow-lg">
      {title}
    </h1>
    
    <div class="flex flex-col items-center gap-3">
      <time datetime={date} class="font-inter text-xs tracking-[0.3em] uppercase text-yokai-white/70">
        {new Date(date).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      
      {tags && tags.length > 0 && (
        <div class="flex gap-4">
          {tags.map(tag => (
            <span class="font-inter text-[9px] tracking-[0.2em] uppercase text-yokai-purple font-bold">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </div>
</header>
