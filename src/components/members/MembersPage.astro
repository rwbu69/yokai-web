---
// src/components/members/MembersPage.astro
//
// AUDIT NOTES (Mei 2026):
// - Import dari ./members.ts (lokal) DIHAPUS — hanya gunakan data dari Sanity
// - Fallback ke localMembers DIHAPUS — empty state ditampilkan jika Sanity kosong
// - Dead reference linkedin DIHAPUS — tidak ada di schema maupun frontend
// - Dead references dp-tenure, dp-city DIHAPUS — elemen tersebut tidak ada di CreditsPanel
// - Field yang di-fetch disesuaikan dengan schema member.ts yang sudah dibersihkan
// - Tipe `any` diganti dengan typed interface
// - useCdn: false sudah di-set di sanityClient

import AccordionStrip from './AccordionStrip.astro';
import CreditsPanel from './CreditsPanel.astro';
import { sanityClient, urlFor } from '@lib/sanity';
import type { SanityImage } from '@lib/sanity';

// ── TypeScript Interfaces ─────────────────────────────────────────────────────

interface SanityMemberDoc {
  _id: string;
  firstName: string;
  role: string;
  quote?: string;
  favoriteWaza?: string[];
  favoriteUchishi?: string[];
  instagram?: string;
  twitter?: string;
  photo?: SanityImage;
  gallery?: SanityImage[];
  sortOrder?: number;
}

// Shape yang digunakan oleh semua komponen members
export interface Member {
  id: number;
  firstName: string;
  role: string;
  quote: string;
  favoriteWaza: string[];
  favoriteUchishi: string[];
  instagram?: string;
  twitter?: string;
  photo: string;
  gallery: [string, string, string, string];
  socials: { instagram?: string; twitter?: string };
}

// ── Fetch dari Sanity ─────────────────────────────────────────────────────────
// Field disesuaikan dengan schema member.ts yang sudah dibersihkan.
// Tidak ada fallback ke file lokal — jika kosong, tampilkan empty state.

const sanityMembers = await sanityClient.fetch<SanityMemberDoc[]>(`
  *[_type == "member"] | order(sortOrder asc, _createdAt asc) {
    _id,
    firstName,
    role,
    quote,
    favoriteWaza,
    favoriteUchishi,
    instagram,
    twitter,
    photo {
      asset,
      hotspot
    },
    "gallery": gallery[] {
      asset,
      hotspot
    },
    sortOrder
  }
`) ?? [];

// ── Resolve Sanity Image URLs ─────────────────────────────────────────────────

const IMG_W = 400;

const members: Member[] = sanityMembers.map((m, i) => {
  const photo = m.photo?.asset
    ? urlFor(m.photo).width(IMG_W).height(600).format('webp').quality(85).url()
    : '';

  // Gallery: harus tepat 4 foto. Jika kurang, isi dengan string kosong.
  const galleryRaw = (m.gallery ?? []).slice(0, 4);
  const gallery = [
    galleryRaw[0]?.asset ? urlFor(galleryRaw[0]).width(IMG_W).height(600).format('webp').quality(85).url() : '',
    galleryRaw[1]?.asset ? urlFor(galleryRaw[1]).width(IMG_W).height(600).format('webp').quality(85).url() : '',
    galleryRaw[2]?.asset ? urlFor(galleryRaw[2]).width(IMG_W).height(600).format('webp').quality(85).url() : '',
    galleryRaw[3]?.asset ? urlFor(galleryRaw[3]).width(IMG_W).height(600).format('webp').quality(85).url() : '',
  ] as [string, string, string, string];

  return {
    id:              i + 1,
    firstName:       m.firstName,
    role:            m.role,
    quote:           m.quote        ?? '',
    favoriteWaza:    Array.isArray(m.favoriteWaza) ? m.favoriteWaza : (m.favoriteWaza ? [m.favoriteWaza as unknown as string] : []),
    favoriteUchishi: Array.isArray(m.favoriteUchishi) ? m.favoriteUchishi : (m.favoriteUchishi ? [m.favoriteUchishi as unknown as string] : []),
    instagram:       m.instagram,
    twitter:         m.twitter,
    photo,
    gallery,
    socials: { instagram: m.instagram, twitter: m.twitter },
  };
});

// ── Slim client payload (hanya field yang dibutuhkan oleh JS browser) ─────────

const clientData = members.map(m => ({
  id:        m.id,
  firstName: m.firstName,
  role:      m.role,
  quote:     m.quote,
  favoriteWaza: m.favoriteWaza,
  favoriteUchishi: m.favoriteUchishi,
  socials:   m.socials,
  gallery:   m.gallery,
  photo:     m.photo,
}));
---

{members.length === 0 ? (
  <!-- Empty State -->
  <div class="w-full h-screen bg-[#0c0c0c] flex flex-col items-center justify-center gap-6 text-center px-6">
    <div class="w-16 h-[1px] bg-yokai-purple/30"></div>
    <p class="font-inter text-[9px] tracking-[0.6em] uppercase text-white/25">
      No Members Yet
    </p>
    <p class="font-outfit text-white/30 text-sm font-light max-w-xs">
      Anggota tim akan muncul di sini setelah ditambahkan melalui Sanity Studio.
    </p>
    <div class="w-16 h-[1px] bg-yokai-purple/30"></div>
  </div>
) : (
  <!--
    members-page class overrides pt-24 that BaseLayout adds for non-home pages.
    Navbar is fixed/sticky and overlays on top — accordion starts flush at top.
  -->
  <div class="members-page flex flex-col bg-[#0c0c0c] overflow-hidden" style="height: 100dvh;">
    <AccordionStrip members={members} />
    <CreditsPanel initial={members[0]} />
  </div>
)}

<!-- ① Data bridge -->
<script define:vars={{ __m: clientData }}>
  window.__YOKAI_M = __m;
</script>

<!-- ② Orchestration script — vanilla JS -->
<script>
  import anime from 'animejs/lib/anime.es.js';

  var members      = (window as any).__YOKAI_M || [];
  var strips        = Array.from(document.querySelectorAll<HTMLElement>('[data-strip-id]'));
  var creditsInner  = document.getElementById('credits-inner');
  var accordion     = document.querySelector<HTMLElement>('.accordion-strip');

  // Detail panel DOM refs
  var dpName1  = document.getElementById('dp-name1');
  var dpRole   = document.getElementById('dp-role');
  var dpFavWaza    = document.getElementById('dp-fav-waza');
  var dpFavUchishi = document.getElementById('dp-fav-uchishi');
  var dpQuote  = document.getElementById('dp-quote');

  var active      = -1;
  var isAnimating = false;

  // ── Pixel-integer widths ─────────────────────────────────────────────
  function getTargetWidths(activeIdx: number) {
    var total  = accordion ? accordion.offsetWidth : window.innerWidth;
    var active = Math.round(total * 0.40);
    var rest   = Math.round((total - active) / (members.length - 1));
    return members.map(function(_: unknown, i: number) { return i === activeIdx ? active : rest; });
  }

  // ── Strip animation ──────────────────────────────────────────────────
  function animateStrips(activeIdx: number) {
    if (isAnimating) return;
    isAnimating = true;
    if (accordion) accordion.style.pointerEvents = 'none';
    var widths = getTargetWidths(activeIdx);
    anime({
      targets: strips,
      width: function(el: HTMLElement, i: number) { return widths[i]; },
      duration: 600,
      easing: 'easeInOutQuart',
      begin: function() {
        strips.forEach(function(s: HTMLElement) { s.style.willChange = 'width'; });
      },
      complete: function() {
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            strips.forEach(function(s: HTMLElement) { s.style.willChange = 'auto'; });
            if (accordion) accordion.style.pointerEvents = '';
            isAnimating = false;
          });
        });
      },
    });
  }

  // ── Social link updater ──────────────────────────────────────────────
  function setSocial(platformId: string, handle: string | undefined, baseUrl: string) {
    var row  = document.getElementById('dp-' + platformId);
    var link = document.getElementById('dp-' + platformId + '-link') as HTMLAnchorElement | null;
    if (!row || !link) return;
    if (handle) {
      row.style.display = '';
      link.textContent  = handle;
      link.href = 'https://' + baseUrl + '/' + handle.replace('@', '');
    } else {
      row.style.display = 'none';
    }
  }

  // ── Gallery updater ──────────────────────────────────────────────────
  function updateGallery(gallery: string[]) {
    for (var i = 0; i < 4; i++) {
      var img = document.getElementById('dp-gallery-' + i) as HTMLImageElement | null;
      if (img && gallery[i]) img.src = gallery[i];
    }
  }

  // ── Detail panel text + gallery update ──────────────────────────────
  function updateDetail(m: { firstName: string; role: string; quote: string; socials: { instagram?: string; twitter?: string }; gallery: string[] }) {
    if (dpName1)      dpName1.textContent      = m.firstName;
    if (dpRole)       dpRole.textContent       = m.role;
    if (dpFavWaza) {
      var w = (m as any).favoriteWaza;
      if (!Array.isArray(w)) w = w ? [w] : [];
      dpFavWaza.textContent = w.length > 0 ? w.join(', ') : '—';
    }
    if (dpFavUchishi) {
      var u = (m as any).favoriteUchishi;
      if (!Array.isArray(u)) u = u ? [u] : [];
      dpFavUchishi.textContent = u.length > 0 ? u.join(', ') : '—';
    }
    if (dpQuote)      dpQuote.textContent      = m.quote;
    setSocial('instagram', m.socials.instagram, 'instagram.com');
    setSocial('twitter',   m.socials.twitter,   'x.com');
    updateGallery(m.gallery || []);
  }

  // ── Core state setter ────────────────────────────────────────────────
  function setActive(idx: number) {
    if (idx === active) return;

    var isFirstLoad = active === -1;
    var dir = idx > active ? -1 : 1;

    strips.forEach(function(s: HTMLElement, i: number) { s.classList.toggle('active', i === idx); });

    var m = members[idx];
    active = idx;
    if (!m) return;

    animateStrips(idx);

    if (isFirstLoad) return;

    var SLIDE = 36;

    anime({
      targets: creditsInner,
      translateX: dir * SLIDE,
      opacity: 0,
      duration: 150,
      easing: 'easeInQuart',
      begin: function() {
        if (creditsInner) creditsInner.style.willChange = 'transform, opacity';
      },
      complete: function() {
        updateDetail(m);
        anime.set(creditsInner, { translateX: -dir * SLIDE });
        anime({
          targets: creditsInner,
          translateX: 0,
          opacity: 1,
          duration: 300,
          easing: 'easeOutQuart',
          complete: function() {
            requestAnimationFrame(function() {
              requestAnimationFrame(function() {
                if (creditsInner) creditsInner.style.willChange = 'auto';
              });
            });
          },
        });
      },
    });
  }

  // ── Event bindings ───────────────────────────────────────────────────
  strips.forEach(function(strip, i) {
    strip.addEventListener('click', function() { setActive(i); });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight') setActive((active + 1) % members.length);
    if (e.key === 'ArrowLeft')  setActive((active + members.length - 1) % members.length);
  });

  // ── Init ─────────────────────────────────────────────────────────────
  setActive(0);
</script>
