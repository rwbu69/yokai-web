---
// src/components/members/MembersPage.astro
// Fetches member data from Sanity (with local fallback).
// Photo and gallery URLs are resolved via Sanity image-url builder.

import AccordionStrip from './AccordionStrip.astro';
import CreditsPanel from './CreditsPanel.astro';
import { members as localMembers, type Member } from './members.ts';
import { sanityClient, urlFor } from '@lib/sanity';

// ── Sanity member shape ───────────────────────────────────────────────
interface SanityMemberDoc {
  _id: string;
  name: string;
  firstName: string;
  lastName: string;
  initials: string;
  role: string;
  tenure?: string;
  city?: string;
  tags?: [string, string];
  quote?: string;
  favoriteWaza?: string;
  favoriteUchishi?: string;
  instagram?: string;
  twitter?: string;
  photo?: object;
  gallery?: object[];
  sortOrder?: number;
}

// ── Try to load from Sanity, fallback to local ─────────────────────────
let members: Member[] = localMembers; // start with local

try {
  const sanityMembers = await sanityClient.fetch<SanityMemberDoc[]>(
    `*[_type == "member"] | order(sortOrder asc, _createdAt asc) {
      _id, name, firstName, lastName, initials, role, tenure, city,
      tags, quote, favoriteWaza, favoriteUchishi, instagram, twitter,
      photo, gallery, sortOrder
    }`
  );

  if (sanityMembers && sanityMembers.length > 0) {
    const W = 400;
    members = sanityMembers.map((m, i) => {
      // Strip photo — use Sanity CDN or fall back to local webp
      const photo = m.photo
        ? urlFor(m.photo).width(W).height(600).format('webp').quality(85).url()
        : (localMembers[i]?.photo ?? '');

      // Gallery — 4 photos from Sanity, or fall back to local picsum placeholders
      const gallery = (m.gallery && m.gallery.length === 4)
        ? m.gallery.map((img) =>
            urlFor(img).width(W).height(600).format('webp').quality(85).url()
          ) as [string, string, string, string]
        : (localMembers[i]?.gallery ?? [
            `https://picsum.photos/seed/${i}a/400/600`,
            `https://picsum.photos/seed/${i}b/400/600`,
            `https://picsum.photos/seed/${i}c/400/600`,
            `https://picsum.photos/seed/${i}d/400/600`,
          ]) as [string, string, string, string];

      return {
        id:              i + 1,
        initials:        m.initials ?? '??',
        firstName:       m.firstName,
        lastName:        m.lastName,
        name:            m.name,
        role:            m.role,
        tenure:          m.tenure ?? '—',
        city:            m.city ?? '—',
        tags:            (m.tags ?? ['—', '—']) as [string, string],
        quote:           m.quote ?? '',
        favoriteWaza:    m.favoriteWaza ?? '—',
        favoriteUchishi: m.favoriteUchishi ?? '—',
        instagram:       m.instagram,
        twitter:         m.twitter,
        gallery,
        photo,
        socials: { instagram: m.instagram, twitter: m.twitter },
      } satisfies Member;
    });
  }
} catch {
  // Silently fall back to local data — site still works
}

// Slim client payload — only fields the script needs (no images in here)
const clientData = members.map(m => ({
  id:        m.id,
  firstName: m.firstName,
  lastName:  m.lastName,
  role:      m.role,
  tenure:    m.tenure,
  city:      m.city,
  quote:     m.quote,
  socials:   m.socials,
  gallery:   m.gallery,    // ← gallery URLs passed to client for live swap
  photo:     m.photo,      // ← strip photo URL for client-side active update
}));
---

<!--
  members-page class overrides pt-24 that BaseLayout adds for non-home pages.
  Navbar is fixed/sticky and overlays on top — accordion starts flush at top.
-->
<div class="members-page flex flex-col bg-[#0c0c0c] overflow-hidden" style="height: 100dvh;">
  <AccordionStrip members={members} />
  <CreditsPanel initial={members[0]} />
</div>


<!-- ① Data bridge -->
<script define:vars={{ __m: clientData }}>
  window.__YOKAI_M = __m;
</script>

<!-- ② Orchestration script — vanilla JS -->
<script>
  import anime from 'animejs/lib/anime.es.js';

  var members      = (window as any).__YOKAI_M || [];
  var strips        = Array.from(document.querySelectorAll<HTMLElement>('[data-strip-id]'));
  var creditsInner  = document.getElementById('credits-inner'); // directional slide target
  var accordion     = document.querySelector<HTMLElement>('.accordion-strip');

  // Detail panel DOM refs
  var dpName1  = document.getElementById('dp-name1');
  var dpName2  = document.getElementById('dp-name2');
  var dpRole   = document.getElementById('dp-role');
  var dpTenure = document.getElementById('dp-tenure');
  var dpCity   = document.getElementById('dp-city');
  var dpQuote  = document.getElementById('dp-quote');

  var active      = -1;
  var isAnimating = false;

  // ── Pixel-integer widths ─────────────────────────────────────────────
  function getTargetWidths(activeIdx: number) {
    var total  = accordion ? accordion.offsetWidth : window.innerWidth;
    var active = Math.round(total * 0.40);
    var rest   = Math.round((total - active) / (members.length - 1));
    return members.map(function(_: any, i: number) { return i === activeIdx ? active : rest; });
  }

  // ── Strip animation ──────────────────────────────────────────────────
  function animateStrips(activeIdx: number) {
    if (isAnimating) return;
    isAnimating = true;
    if (accordion) accordion.style.pointerEvents = 'none';
    var widths = getTargetWidths(activeIdx);
    anime({
      targets: strips,
      width: function(el: HTMLElement, i: number) { return widths[i]; },
      duration: 600,
      easing: 'easeInOutQuart',
      begin: function() {
        strips.forEach(function(s: HTMLElement) { s.style.willChange = 'width'; });
      },
      complete: function() {
        requestAnimationFrame(function() {
          requestAnimationFrame(function() {
            strips.forEach(function(s: HTMLElement) { s.style.willChange = 'auto'; });
            if (accordion) accordion.style.pointerEvents = '';
            isAnimating = false;
          });
        });
      },
    });
  }

  // ── Social link updater ──────────────────────────────────────────────
  function setSocial(platformId: string, handle: string | undefined, baseUrl: string) {
    var row  = document.getElementById('dp-' + platformId);
    var link = document.getElementById('dp-' + platformId + '-link') as HTMLAnchorElement | null;
    if (!row || !link) return;
    if (handle) {
      row.style.display = '';
      link.textContent  = handle;
      link.href = 'https://' + baseUrl + '/' + handle.replace('@', '');
    } else {
      row.style.display = 'none';
    }
  }

  // ── Gallery updater ──────────────────────────────────────────────────
  function updateGallery(gallery: string[]) {
    for (var i = 0; i < 4; i++) {
      var img = document.getElementById('dp-gallery-' + i) as HTMLImageElement | null;
      if (img && gallery[i]) img.src = gallery[i];
    }
  }

  // ── Detail panel text + gallery update ──────────────────────────────
  function updateDetail(m: any) {
    if (dpName1)  dpName1.textContent  = m.firstName;
    if (dpName2)  dpName2.textContent  = m.lastName;
    if (dpRole)   dpRole.textContent   = m.role;
    if (dpTenure) dpTenure.textContent = m.tenure;
    if (dpCity)   dpCity.textContent   = m.city;
    if (dpQuote)  dpQuote.textContent  = m.quote;
    setSocial('instagram', m.socials.instagram, 'instagram.com');
    setSocial('linkedin',  m.socials.linkedin,  'linkedin.com/in');
    setSocial('twitter',   m.socials.twitter,   'x.com');
    updateGallery(m.gallery || []);
  }

  // ── Core state setter ────────────────────────────────────────────────
  function setActive(idx: number) {
    if (idx === active) return;

    var isFirstLoad = active === -1;
    var dir = idx > active ? -1 : 1;

    strips.forEach(function(s: HTMLElement, i: number) { s.classList.toggle('active', i === idx); });

    var m = members[idx];
    active = idx;
    if (!m) return;

    animateStrips(idx);

    if (isFirstLoad) return;

    var SLIDE = 36;

    anime({
      targets: creditsInner,
      translateX: dir * SLIDE,
      opacity: 0,
      duration: 150,
      easing: 'easeInQuart',
      begin: function() {
        if (creditsInner) creditsInner.style.willChange = 'transform, opacity';
      },
      complete: function() {
        updateDetail(m);
        anime.set(creditsInner, { translateX: -dir * SLIDE });
        anime({
          targets: creditsInner,
          translateX: 0,
          opacity: 1,
          duration: 300,
          easing: 'easeOutQuart',
          complete: function() {
            requestAnimationFrame(function() {
              requestAnimationFrame(function() {
                if (creditsInner) creditsInner.style.willChange = 'auto';
              });
            });
          },
        });
      },
    });
  }

  // ── Event bindings ───────────────────────────────────────────────────
  strips.forEach(function(strip, i) {
    strip.addEventListener('click', function() { setActive(i); });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight') setActive((active + 1) % members.length);
    if (e.key === 'ArrowLeft')  setActive((active + members.length - 1) % members.length);
  });

  // ── Init ─────────────────────────────────────────────────────────────
  setActive(0);
</script>
