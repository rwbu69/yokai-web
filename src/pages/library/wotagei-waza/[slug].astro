---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostHeader from '@components/blog/PostHeader.astro';
import PostLayout from '@components/blog/PostLayout.astro';
import { meta } from '@data/wotagei-waza-meta';
import { sanityClient, urlFor } from '../../../lib/sanity';
import { PortableText } from 'astro-portabletext';

export async function getStaticPaths() {
  const query = `*[_type == "waza" && wazaType == "wotagei"] {
    "slug": slug.current
  }`;
  const posts = await sanityClient.fetch(query) || [];
  return posts.map((post: any) => ({
    params: { slug: post.slug }
  }));
}

const { slug } = Astro.params;

const query = `*[_type == "waza" && wazaType == "wotagei" && slug.current == $slug][0] {
  title,
  titleJp,
  date,
  coverImage,
  tags,
  honke,
  body
}`;

const post = await sanityClient.fetch(query, { slug });

if (!post) {
  return Astro.redirect('/404');
}

const coverImageUrl = post.coverImage ? urlFor(post.coverImage).width(1200).url() : '';
---

<BaseLayout title={`${post.title} | ${meta.title}`} activePage="library">
  <main class="min-h-screen bg-[#FAFAFA]">
    <PostHeader
      title={post.title}
      titleJp={post.titleJp}
      coverImage={coverImageUrl}
      date={post.date}
      tags={post.tags}
      honke={post.honke}
    />
    <PostLayout backUrl="/library/wotagei-waza" backText={`Kembali ke ${meta.title}`}>
      <PortableText value={post.body} />
    </PostLayout>
  </main>
</BaseLayout>
