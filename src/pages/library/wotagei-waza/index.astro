---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostHero from '@components/blog/PostHero.astro';
import PostGrid from '@components/blog/PostGrid.astro';
import { meta } from '@data/wotagei-meta';
import { sanityClient, urlFor } from '../../../lib/sanity';

const query = `*[_type == "waza" && wazaType == "wotagei"] | order(dateDesc) {
  "id": slug.current,
  title,
  description,
  date,
  coverImage
}`;

const posts = await sanityClient.fetch(query) || [];
const formattedPosts = posts.map((post: any) => ({
  id: post.id,
  data: {
    title: post.title,
    description: post.description,
    date: post.date,
    coverImage: post.coverImage ? urlFor(post.coverImage).width(800).url() : '',
  }
}));

formattedPosts.sort(
  (a: any, b: any) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<BaseLayout title={`${meta.title} | Yokai Library`} activePage="library">
  <main class="min-h-screen bg-yokai-dark-blue pt-10">
    <PostHero title={meta.heroText} description={meta.description} />
    <PostGrid posts={formattedPosts} collection="wotagei-waza" />
  </main>
</BaseLayout>
