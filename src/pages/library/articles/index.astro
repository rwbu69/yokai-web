---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PostHero from '@components/blog/PostHero.astro';
import PostGrid from '@components/blog/PostGrid.astro';
import { meta } from '@data/articles-meta';

const allPosts: CollectionEntry<'articles'>[] = await getCollection(
  'articles',
  ({ data }) => data.draft !== true
);
allPosts.sort(
  (a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()
);
---

<BaseLayout title={`${meta.title} | Yokai Library`} activePage="library">
  <main class="min-h-screen bg-yokai-dark-blue pt-10">
    <PostHero title={meta.heroText} description={meta.description} />
    <PostGrid posts={allPosts} collection="articles" />
  </main>
</BaseLayout>
