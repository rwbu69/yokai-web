---
import { getCollection, type CollectionEntry, render } from 'astro:content';
import BaseLayout from '@layouts/BaseLayout.astro';
import PostHeader from '@components/blog/PostHeader.astro';
import PostLayout from '@components/blog/PostLayout.astro';
import { meta } from '@data/articles-meta';

export async function getStaticPaths() {
  const posts = await getCollection(
    'articles',
    ({ data }) => data.draft !== true
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'articles'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | ${meta.title}`} activePage="library">
  <main class="min-h-screen bg-yokai-dark-blue">
    <PostHeader
      title={post.data.title}
      coverImage={post.data.coverImage}
      date={post.data.date}
      tags={post.data.tags}
    />
    <PostLayout backUrl="/library/articles" backText={`Kembali ke ${meta.title}`}>
      <Content />
    </PostLayout>
  </main>
</BaseLayout>
