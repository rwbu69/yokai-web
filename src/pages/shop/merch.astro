---
/**
 * src/pages/shop/merch.astro
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import MerchHero from '../../components/shop/merch/MerchHero.astro';
import MerchOrderForm from '../../components/shop/merch/MerchOrderForm.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

import bgImg from '../../assets/photos/3.webp';

const query = `{
  "config": *[_type == "merchConfig"][0] { heroBgImage },
  "items": *[_type == "shopItem" && category == "merch"] | order(_createdAt asc) {
    "id": slug.current,
    title,
    price,
    available,
    description,
    variants
  }
}`;
const data = await sanityClient.fetch(query) || {};
const merchItems = data.items || [];
const merchConfig = data.config || {};
const bgImageUrl = merchConfig.heroBgImage ? urlFor(merchConfig.heroBgImage).width(1920).format('webp').url() : bgImg.src;

const formattedItems = merchItems.map((item: any) => ({
  id: item.id,
  name: item.title,
  price: item.price,
  available: item.available,
  description: item.description,
  variants: item.variants
}));
---

<BaseLayout title="Official Merch | Yokai" activePage="shop">
  <!-- Fullscreen Blurred Background -->
  <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
    <img src={bgImageUrl} alt="Background" class="w-full h-full object-cover scale-110 blur-xl opacity-80" />
    <div class="absolute inset-0 bg-yokai-dark-blue/70"></div>
  </div>

  <main class="relative z-10 min-h-screen flex flex-col">
    <MerchHero />
    
    <section class="w-full px-6 flex-grow flex items-start justify-center pb-32">
      <MerchOrderForm items={formattedItems} />
    </section>
  </main>
</BaseLayout>
