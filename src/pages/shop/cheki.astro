---
/**
 * src/pages/shop/cheki.astro
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChekiHero from '../../components/shop/cheki/ChekiHero.astro';
import ChekiOrderForm from '../../components/shop/cheki/ChekiOrderForm.astro';
import ChekiClosed from '../../components/shop/cheki/ChekiClosed.astro';
import { sanityClient, urlFor } from '../../lib/sanity';

import bgImg from '../../assets/photos/3.webp';

const isDev = import.meta.env.DEV;

const query = `{
  "config": *[_type == "chekiConfig"][0] {
    isOpen, closedMessage, heroBgImage
  },
  "items": *[_type == "shopItem" && category == "cheki"] | order(_createdAt asc) {
    title,
    available
  }
}`;

const data = await sanityClient.fetch(query) || {};
const chekiConfig = data.config || { isOpen: false, closedMessage: 'OUR CHEKI IS CLOSED AT THE MOMENT.' };
const bgImageUrl = chekiConfig.heroBgImage ? urlFor(chekiConfig.heroBgImage).width(1920).format('webp').url() : bgImg.src;
const items = (data.items || []).map((item: any) => ({
  name: item.title,
  available: item.available
}));
---

<BaseLayout title="Polaroid Cheki | Yokai" activePage="shop">
  <!-- Fullscreen Blurred Background -->
  <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
    <img src={bgImageUrl} alt="Background" class="w-full h-full object-cover scale-110 blur-xl opacity-80" />
    <div class="absolute inset-0 bg-yokai-dark-blue/70"></div>
  </div>

  <main class="relative z-10 min-h-screen flex flex-col pb-32">
    <ChekiHero />
    
    <div id="cheki-open-view" class="w-full px-6 flex-grow flex flex-col items-center justify-start" style={`display: ${chekiConfig.isOpen ? 'flex' : 'none'};`}>
      <ChekiOrderForm items={items} />
    </div>

    <div id="cheki-closed-view" class="w-full px-6 flex-grow flex items-start justify-center" style={`display: ${chekiConfig.isOpen ? 'none' : 'flex'};`}>
      <ChekiClosed message={chekiConfig.closedMessage} />
    </div>

    {isDev && (
      <button 
        id="dev-cheki-toggle"
        class="fixed bottom-4 right-4 z-[999] bg-yokai-purple/20 text-yokai-white font-mono text-[10px] uppercase px-4 py-2 border border-yokai-white/20 backdrop-blur-sm cursor-pointer hover:bg-yokai-purple/40 transition-colors"
        data-open={chekiConfig.isOpen.toString()}
      >
        DEV: Cheki [{chekiConfig.isOpen ? 'OPEN' : 'CLOSED'}]
      </button>
    )}
  </main>
</BaseLayout>

<script>
  const devToggle = document.getElementById('dev-cheki-toggle');
  const openView = document.getElementById('cheki-open-view');
  const closedView = document.getElementById('cheki-closed-view');

  if (devToggle) {
    devToggle.addEventListener('click', () => {
      const isCurrentlyOpen = devToggle.getAttribute('data-open') === 'true';
      const newState = !isCurrentlyOpen;
      
      if (newState) {
        openView!.style.display = 'flex';
        closedView!.style.display = 'none';
        devToggle.innerText = 'DEV: Cheki [OPEN]';
      } else {
        openView!.style.display = 'none';
        closedView!.style.display = 'flex';
        devToggle.innerText = 'DEV: Cheki [CLOSED]';
      }

      devToggle.setAttribute('data-open', newState.toString());
    });
  }
</script>
