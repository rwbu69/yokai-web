---
/**
 * order-success.astro
 * 
 * Halaman konfirmasi setelah pemesanan berhasil disubmit.
 * Menangani routing dinamis via query parameter client-side (?type=merch atau ?type=cheki).
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Order Received | Yokai" activePage="shop">
  <div class="min-h-screen bg-yokai-dark-blue flex flex-col items-center justify-center pt-20 pb-10 px-6">
    
    <div class="os-container flex flex-col items-center text-center max-w-md w-full" style="opacity: 0;">
      
      <svg class="os-item w-16 h-16 text-yokai-purple mb-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1" style="opacity: 0;">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>

      <h1 class="os-item font-jakarta font-black uppercase text-yokai-white text-3xl md:text-4xl tracking-tighter leading-none mb-4" style="opacity: 0;">
        WE'VE RECEIVED YOUR ORDER.
      </h1>

      <p class="os-item font-inter text-yokai-white/60 text-xs md:text-sm tracking-widest uppercase mb-12" style="opacity: 0;">
        Please do a confirmation to this number.
      </p>

      <a 
        id="wa-btn"
        href="#" 
        target="_blank" 
        rel="noopener noreferrer"
        class="os-item flex items-center gap-3 bg-yokai-dark-purple text-yokai-white px-8 py-4 font-inter text-xs font-bold tracking-widest uppercase hover:bg-yokai-purple transition-colors duration-300"
        style="opacity: 0;"
      >
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.662-2.062-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        KONFIRMASI VIA WHATSAPP
      </a>

      <a 
        id="back-btn"
        href="/shop/merch" 
        class="os-item mt-8 font-inter text-[10px] tracking-[0.2em] uppercase text-yokai-white/50 hover:text-yokai-purple transition-colors"
        style="opacity: 0;"
      >
        ← Kembali ke toko
      </a>

    </div>
  </div>
</BaseLayout>

<script>
  import anime from 'animejs/lib/anime.es.js';

  const WA_NUMBER = "6289639543238";
  const MSG_MERCH = "Kak, saya barusan melakukan pemesanan merch, ingin konfirmasi apakah sudah masuk atau belum";
  const MSG_CHEKI = "Kak, saya barusan melakukan pemesanan cheki, ingin konfirmasi apakah sudah masuk atau belum";

  document.addEventListener('DOMContentLoaded', () => {
    const urlParams = new URLSearchParams(window.location.search);
    const orderType = urlParams.get('type');

    const waBtn = document.getElementById('wa-btn') as HTMLAnchorElement;
    const backBtn = document.getElementById('back-btn') as HTMLAnchorElement;

    if (orderType === 'cheki') {
      waBtn.href = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(MSG_CHEKI)}`;
      backBtn.href = '/shop/cheki';
    } else {
      waBtn.href = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(MSG_MERCH)}`;
      backBtn.href = '/shop/merch';
    }

    anime.timeline({
      easing: 'easeOutQuart'
    })
    .add({
      targets: '.os-container',
      opacity: 1,
      duration: 100
    })
    .add({
      targets: '.os-item',
      translateY: [20, 0],
      opacity: [0, 1],
      delay: anime.stagger(150),
      duration: 800
    });
  });
</script>
