---
/**
 * src/pages/gallery/photos.astro
 *
 * DIAGNOSIS NOTES (audit Mei 2026):
 * - Fix: `order(dateDesc)` → `order(date desc)` — dateDesc bukan field valid, itu nama ordering
 * - Fix: images projection diperlengkap dengan `{ asset, alt }` agar ref ter-resolve
 * - Fix: Hapus tipe `any` — ganti dengan interface yang proper
 * - Data di-fetch BUILD TIME — sudah benar untuk output: 'static'
 * - useCdn: false sudah di-set di sanityClient
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotosGrid from '../../components/gallery/photos/PhotosGrid.astro';
import { sanityClient, urlFor } from '../../lib/sanity';
import type { SanityImage } from '../../lib/sanity';

// ── TypeScript Interfaces ─────────────────────────────────────────────────────

interface SanityPhotoEventRaw {
  id: string;
  eventName: string;
  date: string;
  caption?: string;
  coverImage?: SanityImage;
  images?: Array<SanityImage & { alt?: string }>;
}

interface FormattedPhotoEvent {
  id: string;
  eventName: string;
  date: string;
  coverImage: string;
  images: string[];
  caption?: string;
}

// ── GROQ Query ────────────────────────────────────────────────────────────────
// Fix: order(date desc) — bukan order(dateDesc)
// Fix: images projection dengan { asset, alt } agar asset reference ter-resolve

const query = `*[_type == "photoEvent"] | order(date desc) {
  "id": _id,
  eventName,
  date,
  caption,
  coverImage {
    asset,
    hotspot
  },
  "images": images[] {
    asset,
    hotspot,
    alt
  }
}`;

const data = await sanityClient.fetch<SanityPhotoEventRaw[]>(query) ?? [];

// ── Resolve Image URLs ────────────────────────────────────────────────────────
// urlFor() dipanggil server-side saat build — aman untuk static output

const formattedEvents: FormattedPhotoEvent[] = data.map((event) => {
  const coverUrl = event.coverImage?.asset
    ? urlFor(event.coverImage).width(1400).height(900).format('webp').url()
    : '';

  const imagesUrls = (event.images ?? [])
    .filter((img) => img?.asset)
    .map((img) => urlFor(img).width(1200).format('webp').url());

  return {
    id:         event.id,
    eventName:  event.eventName,
    date:       event.date,
    coverImage: coverUrl,
    images:     imagesUrls,
    caption:    event.caption,
  };
});
---

<BaseLayout title="Photos | Yokai Gallery" activePage="gallery">
  <PhotosGrid events={formattedEvents} />
</BaseLayout>
