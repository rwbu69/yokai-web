<script>
  import anime from 'animejs/lib/anime.es.js';

  document.addEventListener('DOMContentLoaded', () => {
    // We have 4 tracks. 
    // Track 1 & 3: height 300%, top 0. Slide up means translateY(0) -> translateY(-33.333%) -> translateY(-66.666%)
    // Track 2 & 4: height 300%, bottom 0. Slide down means translateY(0) -> translateY(33.333%) -> translateY(66.666%)

    let state = 0; // 0 = Set A, 1 = Set B, 2 = Set C

    const getTranslateUp = (st: number) => {
      if (st === 0) return '0%';
      if (st === 1) return '-33.333%';
      return '-66.666%';
    };

    const getTranslateDown = (st: number) => {
      if (st === 0) return '0%';
      if (st === 1) return '33.333%';
      return '66.666%';
    };

    setInterval(() => {
      state = (state + 1) % 3;

      // Track 1 (Up)
      anime({
        targets: '.panel-track-1',
        translateY: getTranslateUp(state),
        duration: 1800,
        easing: 'easeInOutExpo',
        delay: 0
