---
import BaseLayout from '../layouts/BaseLayout.astro';

// Import local assets from hero-images folder
import hero1 from '../assets/hero-images/1.jpg';
import hero2 from '../assets/hero-images/2.jpg';
import hero3 from '../assets/hero-images/3.jpg';
import hero4 from '../assets/hero-images/4.jpg';
import hero5 from '../assets/hero-images/5.jpg';
import hero6 from '../assets/hero-images/6.jpg';
import hero7 from '../assets/hero-images/7.jpg';
import hero8 from '../assets/hero-images/8.jpg';
import hero9 from '../assets/hero-images/9.jpg';
import hero10 from '../assets/hero-images/10.jpg';
import hero11 from '../assets/hero-images/11.jpg';
import hero12 from '../assets/hero-images/12.jpg';

// Set A, B, and C for the Hero dynamic panel tracks (4 images per set, totaling 12)
const imagesA = [
  hero1.src,
  hero2.src,
  hero3.src,
  hero4.src
];

const imagesB = [
  hero5.src,
  hero6.src,
  hero7.src,
  hero8.src
];

const imagesC = [
  hero9.src,
  hero10.src,
  hero11.src,
  hero12.src
];

// Carousel images for "Who Are We?" section (All 12 images looping!)
const carouselImages = [
  ...imagesA,
  ...imagesB,
  ...imagesC
];
---

<BaseLayout title="Yokai | Performance Art" activePage="home">
  <!-- TAHAP 2: HERO SECTION -->
  <section class="relative w-full h-screen overflow-hidden bg-yokai-dark-blue flex">
    
    <!-- Panel 1 (Up) -->
    <div class="relative w-1/4 h-full overflow-hidden border-r-[1px] border-yokai-white/10 group">
      <div class="panel-track-1 absolute w-full h-[300%] top-0 left-0 flex flex-col">
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesA[0]}')`}></div>
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesB[0]}')`}></div>
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesC[0]}')`}></div>
      </div>
    </div>

    <!-- Panel 2 (Down) -->
    <div class="relative w-1/4 h-full overflow-hidden border-r-[1px] border-yokai-white/10 group">
      <div class="panel-track-2 absolute w-full h-[300%] bottom-0 left-0 flex flex-col-reverse">
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesA[1]}')`}></div>
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesB[1]}')`}></div>
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesC[1]}')`}></div>
      </div>
    </div>

    <!-- Panel 3 (Up) -->
    <div class="relative w-1/4 h-full overflow-hidden border-r-[1px] border-yokai-white/10 group">
      <div class="panel-track-3 absolute w-full h-[300%] top-0 left-0 flex flex-col">
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesA[2]}')`}></div>
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesB[2]}')`}></div>
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesC[2]}')`}></div>
      </div>
    </div>

    <!-- Panel 4 (Down) -->
    <div class="relative w-1/4 h-full overflow-hidden group">
      <div class="panel-track-4 absolute w-full h-[300%] bottom-0 left-0 flex flex-col-reverse">
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesA[3]}')`}></div>
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesB[3]}')`}></div>
        <div class="w-full h-1/3 bg-cover bg-center grayscale group-hover:grayscale-0 transition-all duration-700" style={`background-image: url('${imagesC[3]}')`}></div>
      </div>
    </div>

    <!-- Subtle Color Overlay for Cinematic Grading -->
    <div class="absolute inset-0 bg-gradient-to-br from-yokai-dark-purple/40 to-yokai-dark-blue/40 mix-blend-multiply pointer-events-none z-[5]"></div>

    <!-- Asymmetrical Typography Overlay -->
