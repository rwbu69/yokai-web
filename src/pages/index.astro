---
/**
 * src/pages/index.astro
 *
 * Landing page — sepenuhnya component-based.
 * Semua konten diimport dari src/components/landing/.
 * File ini tidak mengandung konten yang hardcoded selain struktur import.
 *
 * Urutan section:
 *   1. HeroLanding      — hero full-screen dengan 4 panel gambar
 *   2. Motto            — statement "WE DO NOT JUST PERFORM. WE INOVATE."
 *   3. WhoAreWe         — "WHO ARE WE" dengan mosaic marquee background
 *   4. Projects         — daftar proyek editorial dengan thumbnail YouTube
 *   5. LivePerformances — live performance dengan featured iframe + supporting
 *   6. Footer           — navigasi dan copyright (tetap inline — komponen sederhana)
 */
import BaseLayout       from '../layouts/BaseLayout.astro';
import HeroLanding      from '../components/landing/HeroLanding.astro';
import Motto            from '../components/landing/Motto.astro';
import WhoAreWe         from '../components/landing/WhoAreWe.astro';
import Projects         from '../components/landing/Projects.astro';
import LivePerformances from '../components/landing/LivePerformances.astro';
---

<BaseLayout title="Yokai | Performance Art" activePage="home">

  <!-- ── HERO ── -->
  <HeroLanding />

  <!-- ── MOTTO ── -->
  <Motto />

  <!-- ── WHO ARE WE ── -->
  <WhoAreWe />

  <!-- ── PROJECTS ── -->
  <Projects />

  <!-- ── LIVE PERFORMANCES ── -->
  <LivePerformances />

  <!-- ── FOOTER ── -->
  <footer class="w-full bg-yokai-dark-blue border-t border-yokai-white/10">
    <div class="max-w-[90vw] mx-auto px-6 lg:px-12 py-8 flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="flex items-center gap-6">
        <span class="font-jakarta text-lg font-black uppercase tracking-tighter text-yokai-white">YOKAI</span>
        <span class="w-[1px] h-4 bg-yokai-white/20"></span>
        <span class="font-inter text-[9px] tracking-[0.4em] uppercase text-yokai-light-white/40">Yogyakarta Wotagei Team</span>
      </div>
      <nav class="flex items-center gap-8">
        <a href="/"       class="font-inter text-[9px] tracking-[0.3em] uppercase text-yokai-white"                                     style="transition: color 0.3s;">Home</a>
        <a href="/about"  class="font-inter text-[9px] tracking-[0.3em] uppercase text-yokai-light-white/40 hover:text-yokai-white"     style="transition: color 0.3s;">About</a>
        <a href="/library"class="font-inter text-[9px] tracking-[0.3em] uppercase text-yokai-light-white/40 hover:text-yokai-white"    style="transition: color 0.3s;">Library</a>
        <a href="/gallery" class="font-inter text-[9px] tracking-[0.3em] uppercase text-yokai-light-white/40 hover:text-yokai-white"   style="transition: color 0.3s;">Gallery</a>
        <a href="/shop"    class="font-inter text-[9px] tracking-[0.3em] uppercase text-yokai-light-white/40 hover:text-yokai-white"   style="transition: color 0.3s;">Shop</a>
      </nav>
      <p class="font-inter text-[9px] tracking-[0.3em] uppercase text-yokai-light-white/30">&copy; 2026 Yokai</p>
    </div>
  </footer>

</BaseLayout>
