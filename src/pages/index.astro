    <!-- Mosaic Marquee Background: 3 rows, alternating direction -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-35 flex flex-col gap-1 justify-center">

      <!-- Row 1: imagesA → slides LEFT (slow) -->
      <div class="overflow-hidden h-1/3 flex-shrink-0">
        <div class="flex w-max animate-slide-left h-full gap-1">
          <!-- Set A -->
          {imagesA.map((src) => (
            <img src={src} alt="Yokai" class="h-full w-[240px] flex-shrink-0 object-cover grayscale" />
          ))}
